# Lounge environment variables
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
#
# Lounge runs on Meridian's Supabase project (npuvhxakffxqoszytkxw).
# Use the SAME SUPABASE_URL and ANON_KEY as Meridian; they are not Lounge-specific.

# Supabase (Meridian project)
VITE_SUPABASE_URL=https://npuvhxakffxqoszytkxw.supabase.co
VITE_SUPABASE_ANON_KEY=<copy from Meridian's .env file>

# Stripe (NEW direct account, not the legacy HubSpot one)
# These are PUBLISHABLE keys only. Secret keys live as Supabase edge function secrets.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_or_live_...
VITE_STRIPE_EXPECTED_ACCOUNT_ID=acct_...
